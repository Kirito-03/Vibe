# Configuración de Base de Datos
DB_USER=postgres
DB_PASSWORD=
DB_NAME=vibe

# Token de Cloudflare Tunnel para exponer los servicios
TUNNEL_TOKEN=

# Frontend (Vite) - base URL de la API
# En producción debe ser vacío para usar /api/... en el mismo dominio (Nginx proxy).
VITE_API_BASE=

# Frontend (Vite) - API Key ImgBB (para avatares)
VITE_IMGBB_KEY=tu_key_imgbb_aqui

# (Opcional) Variables de Firebase si el backend las requiere en algún momento
# FIREBASE_PROJECT_ID=vibe-no-sekai-916fa

# Convert (FastAPI) - URL interna (Docker) y timeout de búsqueda/requests
CONVERT_URL=http://convert:8000
CONVERT_TIMEOUT_MS=20000
CONVERT_SEARCH_TIMEOUT_MS=15000
CONVERT_SEARCH_CACHE_TTL_MS=900000

# Worker privado (opcional, vía Tailscale)
MEDIA_WORKER_ENABLED=false
MEDIA_WORKER_URL=
MEDIA_WORKER_TIMEOUT_MS=30000
MEDIA_WORKER_SEARCH_ENABLED=false

# DeepSeek (opcional) - recomendaciones por IA (solo backend)
DEEPSEEK_RECOMMENDATIONS_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=5000
DEEPSEEK_MAX_QUERIES=8

# (Opcional) AI search assist - sólo corrige/expande query (no trae resultados)
AI_SEARCH_ASSIST_ENABLED=false
AI_SEARCH_ASSIST_TIMEOUT_MS=3000
AI_SEARCH_ASSIST_MODEL=deepseek-chat

# Recomendaciones - ventana para evitar repetidos (UserSeenTracks)
RECOMMENDATION_SEEN_TTL_HOURS=24
